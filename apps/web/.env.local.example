# ============================================================================
# MindPolis: apps/web/.env.local.example
# Version: 1.0.0 — 2026-03-07
# Why: Example environment file — copy to .env.local and fill in real values.
#      Never commit .env.local — this example file is safe to commit.
# ============================================================================

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://mindpolis:mindpolis_dev_password@localhost:5432/mindpolis"

# ── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth Providers ─────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Python Scoring Microservice ─────────────────────────────────────────────
# Local dev (docker compose running)
SCORING_SERVICE_URL="http://localhost:8000"
# Production (internal Docker network)
# SCORING_SERVICE_URL="http://scoring-service:8000"

SCORING_SERVICE_SECRET="dev-secret-change-in-production"
