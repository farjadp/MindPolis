// ============================================================================
// MindPolis: schema.prisma
// Version: 1.0.0 — 2026-03-07
// Why: Master database schema — single source of truth for all entities.
//      Designed for research-grade data collection and future ML expansion.
// Env / Identity: Prisma Schema — runs at build/migration time
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// AUTH & IDENTITY
// NextAuth-compatible tables
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          UserRole  @default(PARTICIPANT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // Platform relations
  submissions   AssessmentSubmission[]
  results       AssessmentResult[]
  profile       ParticipantProfile?

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────
// PARTICIPANT PROFILE
// Demographic and research metadata (separate from PII)
// ─────────────────────────────────────────────

model ParticipantProfile {
  id             String    @id @default(cuid())
  userId         String    @unique
  birthYear      Int?
  country        String?
  educationLevel String?   // e.g. "bachelors", "masters", "phd"
  occupation     String?
  politicalSelfId String?  // Self-reported political identity
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("participant_profiles")
}

// ─────────────────────────────────────────────
// ASSESSMENT CATALOG
// The types of tests available (e.g. Political Compass, MFT, Big5)
// ─────────────────────────────────────────────

model Assessment {
  id          String           @id @default(cuid())
  slug        String           @unique  // URL-friendly ID: "political-compass"
  title       String
  description String
  version     String           @default("1.0")
  isActive    Boolean          @default(true)
  isResearch  Boolean          @default(false) // Flags research-grade assessments
  estimatedMinutes Int         @default(10)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // Relations
  questions   Question[]
  dimensions  ScoringDimension[]
  submissions AssessmentSubmission[]
  results     AssessmentResult[]

  @@index([slug])
  @@map("assessments")
}

// ─────────────────────────────────────────────
// QUESTIONS & ITEMS
// Individual assessment questions with type and scoring metadata
// ─────────────────────────────────────────────

model Question {
  id            String       @id @default(cuid())
  assessmentId  String
  order         Int          // Display order within assessment
  text          String       // The question/statement text
  type          QuestionType @default(LIKERT_5)
  category      String?      // Thematic grouping (e.g. "economic", "social")
  dimensionKeys String[]     // Which ScoringDimension keys this question feeds
  isReversed    Boolean      @default(false) // Reverse-scored item
  isActive      Boolean      @default(true)
  metadata      Json?        // Flexible field for researcher annotations

  assessment    Assessment   @relation(fields: [assessmentId], references: [id])
  responses     QuestionResponse[]

  @@index([assessmentId, order])
  @@map("questions")
}

// ─────────────────────────────────────────────
// SCORING DIMENSIONS
// The measured axes (e.g. left/right, authoritarian/libertarian)
// ─────────────────────────────────────────────

model ScoringDimension {
  id           String     @id @default(cuid())
  assessmentId String
  key          String     // Machine key: "economic_axis"
  label        String     // Display label: "Economic Axis"
  description  String?
  minLabel     String?    // E.g. "Communism"
  maxLabel     String?    // E.g. "Capitalism"
  weight       Float      @default(1.0) // Scoring weight multiplier

  assessment   Assessment @relation(fields: [assessmentId], references: [id])

  @@unique([assessmentId, key])
  @@map("scoring_dimensions")
}

// ─────────────────────────────────────────────
// SUBMISSION SESSION
// Records when a user started and completed an assessment
// ─────────────────────────────────────────────

model AssessmentSubmission {
  id           String           @id @default(cuid())
  userId       String
  assessmentId String
  status       SubmissionStatus @default(IN_PROGRESS)
  startedAt    DateTime         @default(now())
  completedAt  DateTime?
  ipAddress    String?
  country      String?
  ipHash       String?          // Hashed IP for fraud detection (not stored raw)
  userAgent    String?          // Browser fingerprint for research QA

  user         User             @relation(fields: [userId], references: [id])
  assessment   Assessment       @relation(fields: [assessmentId], references: [id])
  responses    QuestionResponse[]
  result       AssessmentResult?

  @@index([userId, assessmentId])
  @@map("assessment_submissions")
}

// ─────────────────────────────────────────────
// RAW RESPONSES
// Every individual question answer — the raw data layer
// ─────────────────────────────────────────────

model QuestionResponse {
  id           String   @id @default(cuid())
  submissionId String
  questionId   String
  value        Float    // Normalized numeric value (e.g. 1.0–5.0 for Likert)
  rawValue     String   // Original string response before normalization
  answeredAt   DateTime @default(now())
  latencyMs    Int?     // Time taken to answer in ms (cognitive style research)

  submission   AssessmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question     Question             @relation(fields: [questionId], references: [id])

  @@unique([submissionId, questionId])
  @@index([submissionId])
  @@map("question_responses")
}

// ─────────────────────────────────────────────
// COMPUTED RESULTS
// Output from the Python scoring service — stored after computation
// ─────────────────────────────────────────────

model AssessmentResult {
  id           String   @id @default(cuid())
  userId       String
  assessmentId String
  submissionId String   @unique
  scores       Json     // { dimensionKey: Float } — full dimension score map
  summary      Json     // { label: String, interpretation: String[] }
  percentiles  Json?    // Percentile ranks vs population (computed later)
  clusterLabel String?  // ML cluster assignment (e.g. "Libertarian-Left")
  archetype    String?  // The assigned "Result Identity" (e.g., "The Civic Rationalist")
  topDimensions Json?   // The top 3 strongest dimensions for this user's result
  shareHash    String   @unique @default(uuid()) // Unique ID for public sharing
  modelVersion String   @default("1.0.0") // Python scoring model version
  computedAt   DateTime @default(now())

  user         User                 @relation(fields: [userId], references: [id])
  assessment   Assessment           @relation(fields: [assessmentId], references: [id])
  submission   AssessmentSubmission @relation(fields: [submissionId], references: [id])

  @@index([userId])
  @@index([assessmentId, computedAt])
  @@map("assessment_results")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum UserRole {
  PARTICIPANT    // Standard user
  RESEARCHER     // Read access to anonymized data
  ADMIN          // Full access
}

enum QuestionType {
  LIKERT_5       // 1–5 agreement scale
  LIKERT_7       // 1–7 agreement scale
  BINARY         // Yes / No
  SLIDER         // Continuous 0–100
  FORCED_CHOICE  // Pick one of two options
}

enum SubmissionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}
